{
  "compilerOptions": {
    "target": "es5",
    "module": "esnext",
    "checkJs": false, // 关键：启用 JS 文件类型检查
    "baseUrl": "./",
    "moduleResolution": "node",
    "paths": {
      "@/*": [
        "src/*"
      ]
    },
    "lib": [
      "esnext",
      "dom",
      "dom.iterable",
      "scripthost"
    ]
  },
  "exclude": [
    "node_modules"
  ]
}